{
  "name": "offlid",
  "version": "0.0.0",
  "description": "npx offlid — resolve, verify, and launch the offlid daemon.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "offlid": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@offlid/launcher-core": "workspace:*"
  },
  "optionalDependencies": {
    "//": "Platform daemon binaries are resolved via os/cpu (esbuild-style).",
    "//@offlid/daemon-darwin-arm64": "workspace:*",
    "//@offlid/daemon-darwin-x64": "workspace:*",
    "//@offlid/daemon-linux-x64": "workspace:*",
    "//@offlid/daemon-linux-arm64": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.6.0"
  }
}
