{
  "name": "offlid",
  "version": "0.0.1",
  "description": "The public launcher for Offlid Home.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "offlid": "dist/index.js"
  },
  "files": ["dist/home.js", "dist/index.js", "README.md"],
  "homepage": "https://offlid.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PlawIO/offlid.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/PlawIO/offlid/issues"
  },
  "keywords": ["offlid", "coding-agent", "claude-code", "codex", "ghostty", "developer-tools"],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/*.test.js && node scripts/check-package.mjs && node scripts/smoke-package.mjs",
    "pack:check": "pnpm build && node scripts/check-package.mjs && node scripts/smoke-package.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "~5.6.0"
  }
}
